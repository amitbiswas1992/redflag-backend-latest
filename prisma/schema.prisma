// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Patient {
  id          String    @id @default(uuid())
  epicId      String    @unique // Epic FHIR Patient ID
  name        String?
  firstName   String?
  lastName    String?
  birthDate   DateTime?
  gender      String?
  age         String?
  dateOfBirth String?
  identifiers Json? // Array of identifier objects
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  observations      Observation[]
  conditions        Condition[]
  allergies         Allergy[]
  medications       Medication[]
  procedures        Procedure[]
  encounters        Encounter[]
  diagnosticReports DiagnosticReport[]
  riskEvaluations   RiskEvaluation[]

  @@index([epicId])
  @@map("patients")
}

model Practitioner {
  id             String    @id @default(uuid())
  epicId         String    @unique // Epic FHIR Practitioner ID
  name           String?
  firstName      String?
  lastName       String?
  prefix         String[]
  suffix         String[]
  gender         String?
  birthDate      DateTime?
  identifiers    Json? // Array of identifier objects
  telecom        Json? // Array of telecom objects
  address        Json? // Array of address objects
  qualifications Json? // Array of qualification objects
  languages      String[]
  deaNumber      String? // prescriber_dea
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([epicId])
  @@map("practitioners")
}

model Observation {
  id        String    @id @default(uuid())
  epicId    String    @unique // Epic FHIR Observation ID
  patientId String
  testName  String?
  value     String?
  date      DateTime?
  status    String?
  code      String? // Original code
  display   String? // Original display
  category  String?
  unit      String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@index([epicId])
  @@map("observations")
}

model Condition {
  id           String    @id @default(uuid())
  epicId       String    @unique // Epic FHIR Condition ID
  patientId    String
  diagnosis    String?
  status       String?
  onsetDate    DateTime?
  recordedDate DateTime?
  code         String? // Original code
  display      String? // Original display
  category     String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@index([epicId])
  @@map("conditions")
}

model Allergy {
  id           String    @id @default(uuid())
  epicId       String    @unique // Epic FHIR AllergyIntolerance ID
  patientId    String
  allergen     String?
  type         String?
  severity     String?
  status       String?
  recordedDate DateTime?
  code         String? // Original code
  display      String? // Original display
  category     String[]
  criticality  String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@index([epicId])
  @@map("allergies")
}

model Medication {
  id           String    @id @default(uuid())
  epicId       String    @unique // Epic FHIR MedicationStatement ID
  patientId    String
  medication   String?
  status       String?
  dosage       String?
  route        String?
  startDate    DateTime?
  endDate      DateTime?
  dateAsserted DateTime?
  code         String? // Original code
  display      String? // Original display

  // Additional fields to support violation rules (all nullable)
  controlledSubstancePrescribed Boolean? // controlled_substance_prescribed
  refillCount                   Int? // refill_count
  autoRefillEnabled             Boolean? // auto_refill_enabled
  medicationAdherence           String? // medication_adherence
  clinicalDecisionSupport       Int? // clinical_decision_support
  overrideReason                String? // override_reason
  quantity                      Int? // substance.instance.quantity
  substanceCode                 String? // substance.code
  substanceExpiry               DateTime? // substance.instance.expiry
  prescriptionWritten           Boolean? // prescription_written

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@index([epicId])
  @@map("medications")
}

model Procedure {
  id            String    @id @default(uuid())
  epicId        String    @unique // Epic FHIR Procedure ID
  patientId     String
  procedure     String?
  status        String?
  date          DateTime?
  outcome       String?
  code          String? // Original code
  display       String? // Original display
  category      String?
  performedDate DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@index([epicId])
  @@map("procedures")
}

model Encounter {
  id        String    @id @default(uuid())
  epicId    String    @unique // Epic FHIR Encounter ID
  patientId String
  visitType String?
  reason    String?
  startDate DateTime?
  endDate   DateTime?
  status    String?
  type      String? // FHIR Encounter.type (coded)
  class     String? // FHIR Encounter.class (coded)

  // Additional FHIR R5 Encounter fields (all nullable)
  priority        String? // FHIR Encounter.priority
  serviceType     String? // FHIR Encounter.serviceType
  subjectStatus   String? // FHIR Encounter.subjectStatus
  lengthMinutes   Int? // FHIR Encounter.length (duration in minutes)
  serviceProvider String? // FHIR Encounter.serviceProvider (organization reference id)
  partOfId        String? // FHIR Encounter.partOf (parent encounter)

  // Telehealth & documentation-related fields (from rules doc, all nullable)
  practitionerName        String? // practitionerName
  isTelehealth            Boolean? // is_telehealth
  telehealthId            String? // telehealth_id
  patientIdentityVerified Boolean? // patient_identity_verified
  consentObtained         Boolean? // consent_obtained
  sessionRecordingConsent Boolean? // session_recording_consent
  providerLocation        String? // provider_location
  providerLocationState   String? // provider_location_state
  patientLocation         String? // patient_location
  patientLocationState    String? // patient_location_state
  stateLicensureVerified  Json? // state_licensure_verified (per-state map)
  crossStateLicense       Boolean? // cross_state_license
  encounterType           String? // encounter_type (e.g. 'New')
  sessionDurationMinutes  Int? // session_duration
  sessionStartTime        DateTime? // session_start_time
  sessionEndTime          DateTime? // session_end_time
  mentalHealthScreening   String? // mental_health_screening
  substanceUseScreening   String? // substance_use_screening
  chiefComplaint          String? // chief_complaint
  followUpScheduled       Boolean? // follow_up_scheduled
  carePlanUpdated         Boolean? // care_plan_updated
  vitalSignsRecorded      Boolean? // vital_signs_recorded
  outcomeMeasured         String? // outcome_measured
  coordinationWithPcp     Boolean? // coordination_with_pcp
  clinicalNotesCompleted  String? // clinical_notes_completed
  noteSignedDate          DateTime? // note_signed_date
  allergiesReviewed       Boolean? // allergies_reviewed
  technologyAssessment    String? // technology_assessment
  informedConsentType     String? // informed_consent_type
  clinicalDecisionMaker   String? // clinical_decision_maker
  qualityMeasureMet       Boolean? // quality_measure_met

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  patient       Patient     @relation(fields: [patientId], references: [id], onDelete: Cascade)
  partOf        Encounter?  @relation("EncounterPartOf", fields: [partOfId], references: [id])
  subEncounters Encounter[] @relation("EncounterPartOf")

  @@index([patientId])
  @@index([epicId])
  @@index([partOfId])
  @@map("encounters")
}

model DiagnosticReport {
  id            String    @id @default(uuid())
  epicId        String    @unique // Epic FHIR DiagnosticReport ID
  patientId     String
  reportName    String?
  status        String?
  date          DateTime?
  conclusion    String?
  code          String? // Original code
  display       String? // Original display
  category      String?
  effectiveDate DateTime?
  issuedDate    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@index([epicId])
  @@map("diagnostic_reports")
}

enum IngestionJobStatusV2 {
  CREATED
  UPLOADED
  RUNNING
  COMPLETED
  FAILED
}

enum IngestionRowOutcomeV2 {
  INSERTED
  UPDATED
  SKIPPED
  ERROR
}

model IngestionJobV2 {
  id              String               @id @default(uuid())
  sourceType      String
  templateVersion String?
  status          IngestionJobStatusV2 @default(CREATED)
  checksumSha256  String?
  totalRows       Int                  @default(0)
  processedRows   Int                  @default(0)
  successRows     Int                  @default(0)
  failedRows      Int                  @default(0)
  mappingManifest Json?
  errorSummary    Json?
  startedAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  rows IngestionRowResultV2[]

  @@index([status])
  @@index([sourceType])
  @@index([createdAt])
  @@map("ingestion_jobs_v2")
}

model IngestionRowResultV2 {
  id             String               @id @default(uuid())
  jobId          String
  rowNumber      Int
  sourceRecordKey String?
  entityType     String?
  outcome        IngestionRowOutcomeV2
  reasonCode     String?
  message        String?
  rowData        Json?                @map("row_data")
  persisted      Json?
  createdAt      DateTime             @default(now())

  job IngestionJobV2 @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
  @@index([jobId, rowNumber])
  @@index([outcome])
  @@map("ingestion_row_results_v2")
}

model RiskRule {
  id                 String   @id @default(uuid())
  roleName           String // Name of the role/rule
  ruleCode           String? // Rule code (e.g., "TH-001")
  riskLevel          String // Risk level (e.g., "low", "medium", "high", "critical")
  eventName          String? // Event/activity type: Observation, Condition, Allergy, Medication, Procedure, Encounter, DiagnosticReport (optional for multi-condition rules)
  score              Int // Score/points assigned when rule matches
  conditionLogic     String   @default("AND") // Logic to combine conditions: "AND" or "OR"
  affectedVariables  String[] // List of affected variables
  taxonomy           String? // Taxonomy classification (e.g., "HSCR2: Regulatory Risk → HSCR3: Federal DEA Compliance Violation")
  regulatoryCitation String? // Regulatory citation (e.g., "21 USC § 829(e)")
  redFlags           String[] // Array of red flag descriptions
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  // Relations
  conditions  RuleCondition[]
  evaluations RiskEvaluation[]

  // Legacy fields for backward compatibility (deprecated)
  field    String? // Field name to check (deprecated - use conditions instead)
  operator String? // Operator (deprecated - use conditions instead)
  value    String? // Comparison value (deprecated - use conditions instead)

  @@index([eventName])
  @@index([isActive])
  @@index([ruleCode])
  @@map("risk_rules")
}

model RuleCondition {
  id        String   @id @default(uuid())
  ruleId    String
  rule      RiskRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  field     String // Field name to check (e.g., "controlled_substance_prescribed", "patient_identity_verified")
  operator  String // Operator: "=", "!=", "<", ">", "<=", ">=", "contains", "startsWith", "endsWith", "IS_NULL", "IS_NOT_NULL"
  value     String? // Comparison value (nullable for IS_NULL/IS_NOT_NULL operators)
  order     Int // Order of condition in the rule (for proper evaluation sequence)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ruleId])
  @@index([ruleId, order])
  @@map("rule_conditions")
}

model RiskEvaluation {
  id           String   @id @default(uuid())
  patientId    String
  patient      Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  ruleId       String
  rule         RiskRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  matched      Boolean // Whether the rule matched
  matchedValue String? // The actual value that matched
  score        Int // Score from the rule
  evaluatedAt  DateTime @default(now())
  eventType    String // Type of event that triggered evaluation
  eventId      String? // ID of the specific event that matched (e.g., observation ID)

  @@index([patientId])
  @@index([ruleId])
  @@index([evaluatedAt])
  @@index([eventType])
  @@map("risk_evaluations")
}

model IngestionStat {
  id                String   @id @default(uuid())
  date              DateTime @default(now()) // When the ingestion occurred (timestamp)
  source            String? // Optional source label, e.g. "FHIR_JSON", "FHIR_XML", "BULK"
  patients          Int      @default(0)
  observations      Int      @default(0)
  conditions        Int      @default(0)
  allergies         Int      @default(0)
  medications       Int      @default(0)
  procedures        Int      @default(0)
  encounters        Int      @default(0)
  diagnosticReports Int      @default(0)
  createdAt         DateTime @default(now())

  @@index([date])
  @@map("ingestion_stats")
}
