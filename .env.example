# Server Configuration
PORT=3000

# Epic SMART on FHIR Configuration
# Set EPIC_USE_SANDBOX=true to use Epic's FHIR Developer Sandbox
EPIC_USE_SANDBOX=true

# Client ID from Epic App Orchard (Backend Systems application)
# For Sandbox: Use Non-Production Client ID
# For Production: Use Production Client ID
EPIC_CLIENT_ID=bdaa184c-2f0a-4e74-870b-ad762575db75

# JWT Backend Service Configuration
# Generate key pair using: npm run generate-keys
# Upload public_key.pem to Epic App Orchard and get Key ID (KID)
# Private key file path (recommended - keep private_key.pem secure!)

EPIC_JWT_PRIVATE_KEY_PATH=private_key.pem


# Alternative: Inline key value
# EPIC_JWT_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----
# Your private key here
# -----END PRIVATE KEY-----
EPIC_JWT_KEY_ID=your-key-id-from-epic

# JWT Issuer and Subject (typically your Client ID)
EPIC_JWT_ISSUER=bdaa184c-2f0a-4e74-870b-ad762575db75
EPIC_JWT_SUBJECT=bdaa184c-2f0a-4e74-870b-ad762575db75

# JWT Audience (FHIR Base URL - auto-configured if EPIC_USE_SANDBOX=true)
# EPIC_JWT_AUDIENCE=https://fhir.epic.com/interconnect-fhir-oauth/api/FHIR/R4

# If EPIC_USE_SANDBOX=true, these URLs are auto-configured
# If EPIC_USE_SANDBOX=false, provide your organization's URLs:
# EPIC_FHIR_BASE_URL=https://your-org.epic.com/interconnect-fhir-oauth/api/FHIR/R4
# EPIC_TOKEN_URL=https://your-org.epic.com/interconnect-fhir-oauth/oauth2/token

# SMART on FHIR Scopes (space-separated)
EPIC_SCOPE=system/Patient.read system/Observation.read system/Condition.read system/Practitioner.read


# This was inserted by `prisma init`:
# Environment variables declared in this file are NOT automatically loaded by Prisma.
# Please add `import "dotenv/config";` to your `prisma.config.ts` file, or use the Prisma CLI with Bun
# to load environment variables from .env files: https://pris.ly/prisma-config-env-vars.

# Prisma supports the native connection string format for PostgreSQL, MySQL, SQLite, SQL Server, MongoDB and CockroachDB.
# See the documentation for all the connection string options: https://pris.ly/d/connection-strings

DB_HOST=postgres
DB_PORT=5432
DB_NAME=redflag_db
DB_USERNAME=redflag_user
DB_PASSWORD=AA57SzzYt5XTwu3m52E4Qw
# Docker Compose uses the postgres service name so the backend container can reach the local database.
DATABASE_URL=postgresql://${DB_USERNAME}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}
ADMINER_PORT=8060

# Frontend Origin (used for CORS)
FRONTEND_ORIGIN=http://localhost:3002

# Keycloak Configuration
KEYCLOAK_PORT=8080
KEYCLOAK_URL=http://localhost:${KEYCLOAK_PORT}
KEYCLOAK_REALM=redflag-saas
KEYCLOAK_CLIENT_ID=redflag-web-app
KEYCLOAK_CLIENT_SECRET=your-keycloak-client-secret
IDENTITY_PORT=3001
JWT_SECRET=eaf11913e6fa331b0b197046d62c7959f54607841b5b76c96a55a344d4644ca1
JWT_EXPIRES_IN=15m

# Soketi (Pusher-compatible WebSocket server)
SOKETI_PORT=6001
SOKETI_DEFAULT_APP_ID=your-app-id
SOKETI_DEFAULT_APP_KEY=your-app-key
SOKETI_DEFAULT_APP_SECRET=your-app-secret
