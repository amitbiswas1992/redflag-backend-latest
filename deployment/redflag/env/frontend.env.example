# Public URLs consumed in browser
NEXT_PUBLIC_API_URL=https://api.example.com
NEXT_PUBLIC_IDENTITY_API_URL=https://identity.example.com

# NextAuth
NEXTAUTH_URL=https://app.example.com
NEXTAUTH_SECRET=replace-with-long-random-secret

# Server-side URL used by NextAuth callback in container
IDENTITY_API_URL=http://redflag-identity:3001

# OIDC / Keycloak (public URL)
KEYCLOAK_URL=https://auth.example.com
KEYCLOAK_REALM=redflag-saas
KEYCLOAK_CLIENT_ID=redflag-web-app
KEYCLOAK_CLIENT_SECRET=
